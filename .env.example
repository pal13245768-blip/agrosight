# =============================================================================
#  AgroSight – Environment Configuration
#  Copy this to .env and fill in your values before running any script.
#  Never commit .env to git.
# =============================================================================

# ── LLM (required for /chat endpoint) ────────────────────────────────────
MISTRAL_API_KEY=YOUR_MISTRAL_API_KEY
MISTRAL_MODEL=mistral-large-latest
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# ── Qdrant vector database ────────────────────────────────────────────────
QDRANT_URL=YOUR_QDRANT_URL
QDRANT_API_KEY=YOUR_QDRANT_API_KEY
QDRANT_COLLECTION=agricultural_knowledge_v4

# ── Embedding (UPGRADED as per strategy report) ───────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# ── Retrieval settings ───────────────────────────────────────────────────
RETRIEVAL_TOP_K=8
RETRIEVAL_SCORE_THRESHOLD=0.25
DEFAULT_CHUNK_TOKENS=512
DEFAULT_OVERLAP_TOKENS=64

# ── Redis session store ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=86400
MAX_HISTORY_TURNS=5

# ── OpenWeatherMap ────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# ── India Open Government Data ────────────────────────────────────────────
DATA_GOV_API_KEY_1=YOUR_DATA_GOV_API_KEY
DATA_GOV_BASE_URL=https://data.gov.in/api
data_gov_mandi_resource_id=35985678-0d79-46b4-9ed6-6f13308a1d24

# ── Agmarknet market price ────────────────────────────────────────────────
AGMARKNET_API_KEY=YOUR_AGMARKNET_API_KEY
AGMARKNET_BASE_URL=https://agmarknet.gov.in/api

# ── USDA NASS crop statistics ─────────────────────────────────────────────
USDA_NASS_API_KEY=YOUR_USDA_NASS_API_KEY
USDA_NASS_BASE_URL=https://quickstats.nass.usda.gov/api

# ── Kaggle (for PlantVillage disease images) ──────────────────────────────
KAGGLE_USERNAME=YOUR_KAGGLE_USERNAME
KAGGLE_KEY=YOUR_KAGGLE_KEY

# ── FAO FAOSTAT ───────────────────────────────────────────────────────────
FAO_FAOSTAT_BASE_URL=https://fenixservices.fao.org/faostat/api/v1

# ── ISRIC SoilGrids ───────────────────────────────────────────────────────
ISRIC_BASE_URL=https://rest.isric.org/soilgrids/v2.0

# ── App runtime ───────────────────────────────────────────────────────────
APP_TITLE=AgroSight RAG API
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
MAX_AGENT_ITERATIONS=6
REQUEST_TIMEOUT=30

# ── Data paths ────────────────────────────────────────────────────────────
DATA_ROOT=./data/raw
BOOKS_DIR=./data/books 

CHUNKS_OUTPUT_DIR=./chunks_output
MAX_RETRIES=3
RETRY_BACKOFF=2
BATCH_SIZE=1000
